# Supabase (shared between skyforest.by and skyforest.ai)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Brand: omit or "skyforest" for .by | "samplify" or "ai" for skyforest.ai
NEXT_PUBLIC_BRAND=skyforest

# App URL (used in email templates; override for staging/dev)
NEXT_PUBLIC_APP_URL=https://skyforest.by

# bePaid (payments — skyforest.by only)
BEPAID_SHOP_ID=your-shop-id
BEPAID_SECRET_KEY=your-secret-key

# Stripe (payments — skyforest.ai only)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook URL in Stripe Dashboard: https://skyforest.ai/api/payment/stripe-webhook

# Vercel Cron authorization (min 16 characters)
CRON_SECRET=your-cron-secret-min-16-chars

# Email (Gmail SMTP)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@skyforest.by

# Supabase "Send Email" auth hook secret (Dashboard → Authentication → Hooks).
# When set + hook enabled, confirmation/recovery/etc. emails are rendered by the
# app (src/app/api/auth/send-email) brand-aware: .ai → English + support@skyforest.ai,
# .by → Russian + support@skyforest.by. Format: v1,whsec_...
# NOTE: the From mailbox (support@skyforest.ai / support@skyforest.by) must be an
# authorized sender on the SMTP account above, or delivery will fail / land in spam.
SEND_EMAIL_HOOK_SECRET=v1,whsec_your-hook-secret

# Weather data source
# Default provider: "open-meteo" (free) or "visual-crossing"
WEATHER_PROVIDER=open-meteo
# Visual Crossing Timeline API key (enables the "Visual Crossing" source)
VISUAL_CROSSING_API_KEY=your-visual-crossing-key

# Kindwise mushroom.id — распознавание грибов по фото (фича «Определение гриба по фото»).
# Тот же ключ, что использует Telegram-бот Mashbot. СЕРВЕРНЫЙ секрет — НИКОГДА не
# кладите его в NEXT_PUBLIC_* и не отдавайте клиенту.
KINDWISE_API_KEY=your-kindwise-api-key
# Базовый URL API (опционально; по умолчанию https://mushroom.kindwise.com/api/v1)
KINDWISE_BASE_URL=https://mushroom.kindwise.com/api/v1

# Google Earth Engine (optional, for MODIS land cover)
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
